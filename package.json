{
  "name": "knigotrek",
  "private": true,
  "version": "1.0.0",
  "description": "Книготрек — бесплатный десктоп-трекер прогресса для писателей: статистика, цели, PDF-отчёты и режим фокуса. Electron + React + SQLite.",
  "license": "MIT",
  "author": {
    "name": "litsos629",
    "email": "litsos629@users.noreply.github.com"
  },
  "homepage": "https://github.com/litsos629/knigotrek",
  "repository": {
    "type": "git",
    "url": "https://github.com/litsos629/knigotrek.git"
  },
  "bugs": {
    "url": "https://github.com/litsos629/knigotrek/issues"
  },
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "NODE_ENV=development concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "dist": "electron-builder",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "type-check": "tsc --noEmit",
    "check": "npm run lint && npm run type-check && npm run test:run",
    "check:all": "npm run lint && npm run type-check && npm run test:run && npm run test:coverage",
    "start": "./start.sh",
    "start:check": "./start.sh --check",
    "icons": "node scripts/generate-icons.js",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder --win --mac --linux",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "better-sqlite3": "^12.6.2",
    "date-fns": "^4.1.0",
    "html2canvas": "^1.4.1",
    "i18next": "^26.3.1",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.8",
    "react-qr-code": "^2.0.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.16",
    "canvas": "^3.2.1",
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.33",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.knigotrek.app",
    "productName": "Книготрек",
    "copyright": "Copyright © 2024-2026 litsos629",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Книготрек"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Office",
      "executableName": "knigotrek",
      "syncDesktopName": true
    },
    "publish": null,
    "artifactName": "knigotrek-${version}-${os}-${arch}.${ext}"
  },
  "allowScripts": {
    "better-sqlite3@12.6.2": true,
    "canvas@3.2.1": true,
    "core-js@3.48.0": true,
    "electron@40.10.3": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.27.7": true,
    "lzma-native@8.0.6": true,
    "sharp@0.34.5": true
  }
}
